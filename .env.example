# OpenAgentNet Backend Configuration

# Database
DATABASE_URL=postgresql+asyncpg://openagentnet:openagentnet@localhost:5432/openagentnet

# Redis
REDIS_URL=redis://localhost:6379/0

# NATS
NATS_URL=nats://localhost:4222

# JWT
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# API
API_V1_PREFIX=/v1
CORS_ORIGINS=["http://localhost:3000"]

# Trust score weights
TRUST_WEIGHT_OUTCOME=0.40
TRUST_WEIGHT_LATENCY=0.25
TRUST_WEIGHT_DISPUTE=0.25
TRUST_WEIGHT_AGE=0.10

# Rate limits (per minute)
RATE_LIMIT_REGISTER=10
RATE_LIMIT_DISCOVER=200
RATE_LIMIT_MESSAGES=1000
RATE_LIMIT_ENDORSE=50
